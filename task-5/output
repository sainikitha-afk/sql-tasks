**Query #3**

    -- 1. Subquery in WHERE (Non-Correlated)
    -- Employees earning ABOVE overall average salary
    SELECT name, salary
    FROM Employees
    WHERE salary > (
        SELECT AVG(salary) FROM Employees
    );


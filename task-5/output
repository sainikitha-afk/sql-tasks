**Query #5**

    -- 3. Subquery in SELECT (Dynamic Column)
    -- Show each employee + department average salary
    SELECT 
        name,
        department,
        salary,
        (
            SELECT AVG(e2.salary)
            FROM Employees e2
            WHERE e2.department = e1.department
        ) AS dept_avg_salary
    FROM Employees e1;


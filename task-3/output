**Query #3**

    -- 1. COUNT employees per department
    SELECT department, COUNT(*) AS total_employees
    FROM Employees
    GROUP BY department;

| department  | total_employees |
| ----------- | --------------- |
| Engineering | 2               |
| HR          | 1               |
| Marketing   | 1               |
| Sales       | 2               |

---
**Query #4**

    -- 2. AVG salary per department
    SELECT department, AVG(salary) AS avg_salary
    FROM Employees
    GROUP BY department;

| department  | avg_salary |
| ----------- | ---------- |
| Engineering | 77500.0    |
| HR          | 50000.0    |
| Marketing   | 60000.0    |
| Sales       | 60000.0    |

---
**Query #5**

    -- 3. SUM salary per department
    SELECT department, SUM(salary) AS total_salary
    FROM Employees
    GROUP BY department;

| department  | total_salary |
| ----------- | ------------ |
| Engineering | 155000       |
| HR          | 50000        |
| Marketing   | 60000        |
| Sales       | 120000       |

---
**Query #6**

    -- 4. HAVING clause (departments with more than 1 employee)
    SELECT department, COUNT(*) AS total_employees
    FROM Employees
    GROUP BY department
    HAVING COUNT(*) > 1;

| department  | total_employees |
| ----------- | --------------- |
| Engineering | 2               |
| Sales       | 2               |


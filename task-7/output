**Query #7**

    -- =====================================
    -- 5. LEAD()
    -- Next employee salary in same dept
    -- =====================================
    SELECT 
        name,
        department,
        salary,
        LEAD(salary) OVER (
            PARTITION BY department
            ORDER BY salary DESC
        ) AS next_salary
    FROM Employees;

